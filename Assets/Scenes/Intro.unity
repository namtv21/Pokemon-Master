  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: " Project n\xE0y l\xE0 m\u1ED9t fan-made game l\u1EA5y c\u1EA3m h\u1EE9ng
    t\u1EEB Pok\xE9mon, \u0111\u01B0\u1EE3c th\u1EF1c hi\u1EC7n cho m\u1EE5c \u0111\xEDch
    h\u1ECDc t\u1EADp v\xE0 th\u1EF1c h\xE0nh ph\xE1t tri\u1EC3n game. Ph\xE1t tri\u1EC3n
    b\u1EDFi Tr\u1EA7n V\u0103n Nam (Email: tvnamtv21@gmail.com).\n\n Tr\xF2 ch\u01A1i
    kh\xF4ng c\xF3 li\xEAn h\u1EC7, t\xE0i tr\u1EE3, hay x\xE1c nh\u1EADn ch\xEDnh
    th\u1EE9c t\u1EEB Nintendo, Game Freak, Creatures Inc., The Pok\xE9mon Company,
    hay b\u1EA5t k\u1EF3 \u0111\u01A1n v\u1ECB s\u1EDF h\u1EEFu b\u1EA3n quy\u1EC1n
    n\xE0o.\n\n To\xE0n b\u1ED9 t\xEAn ri\xEAng, nh\xE2n v\u1EADt, h\xECnh \u1EA3nh
    v\xE0 th\u01B0\u01A1ng hi\u1EC7u Pok\xE9mon thu\u1ED9c v\u1EC1 ch\u1EE7 s\u1EDF
    h\u1EEFu t\u01B0\u01A1ng \u1EE9ng. D\u1EF1 \xE1n n\xE0y kh\xF4ng nh\u1EB1m m\u1EE5c
    \u0111\xEDch th\u01B0\u01A1ng m\u1EA1i."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
