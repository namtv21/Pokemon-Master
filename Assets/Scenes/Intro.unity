MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 93793167}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b0bc640e58941354f96071f75744abb9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  nextSceneName: Town01
  fadeDuration: 1
  disclaimerCanvas: {fileID: 1804283303}
  disclaimerText: {fileID: 1508274997}
  disclaimerHoldTime: 4
  disclaimerContent: "D\u1EF1 \xE1n fan-made n\xE0y \u0111\u01B0\u1EE3c t\u1EA1o
    ra cho m\u1EE5c \u0111\xEDch h\u1ECDc t\u1EADp v\xE0 th\u1EF1c h\xE0nh ph\xE1t
    tri\u1EC3n game.\n\nTr\xF2 ch\u01A1i kh\xF4ng c\xF3 li\xEAn h\u1EC7, t\xE0i tr\u1EE3
    hay x\xE1c nh\u1EADn ch\xEDnh th\u1EE9c t\u1EEB Nintendo, Game Freak, Creatures
    Inc., The Pok\xE9mon Company ho\u1EB7c b\u1EA5t k\u1EF3 \u0111\u01A1n v\u1ECB
    s\u1EDF h\u1EEFu b\u1EA3n quy\u1EC1n n\xE0o.\n\nPok\xE9mon, t\xEAn ri\xEAng,
    nh\xE2n v\u1EADt v\xE0 t\xE0i s\u1EA3n li\xEAn quan thu\u1ED9c quy\u1EC1n s\u1EDF
    h\u1EEFu c\u1EE7a ch\u1EE7 s\u1EDF h\u1EEFu t\u01B0\u01A1ng \u1EE9ng."
  oakCanvas: {fileID: 561142445}
  oakSpriteImage: {fileID: 1628009163}
  dialogPanel: {fileID: 0}
  oakDialogText: {fileID: 1698854924}
  pressZHint: {fileID: 1517595764}
  typewriterDelay: 0.035
  oakLines:
  - "Ch\xE0o m\u1EEBng \u0111\u1EBFn v\u1EDBi th\u1EBF gi\u1EDBi Pok\xE9mon!"
  - "Th\u1EBF gi\u1EDBi n\xE0y t\u1ED3n t\u1EA1i song song v\u1EDBi th\u1EBF gi\u1EDBi
    c\u1EE7a con ng\u01B0\u1EDDi...\n\u1EA9n ch\u1EE9a v\xF4 s\u1ED1 sinh v\u1EADt
    k\u1EF3 di\u1EC7u ch\u01B0a \u0111\u01B0\u1EE3c kh\xE1m ph\xE1."
  - "Ta l\xE0 Gi\xE1o s\u01B0 Oke \u2014 nh\xE0 nghi\xEAn c\u1EE9u Pok\xE9mon h\xE0ng
    \u0111\u1EA7u v\xF9ng n\xE0y."
  - "Pok\xE9mon c\xF3 th\u1EC3 l\xE0 \u0111\u1ED1i t\xE1c chi\u1EBFn \u0111\u1EA5u,
    ng\u01B0\u1EDDi b\u1EA1n \u0111\u1ED3ng h\xE0nh\nv\xE0 \u0111\xF4i khi... l\xE0
    c\u1EA3 gia \u0111\xECnh."
  - "H\xE0nh tr\xECnh c\u1EE7a c\u1EADu s\u1EAFp b\u1EAFt \u0111\u1EA7u.\nH\xE3y
    c\u1EA9n th\u1EADn \u2014 v\xE0 ch\xFAc may m\u1EAFn!"
